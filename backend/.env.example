PORT=5000

# MongoDB Connection String (Replace with your own cluster URL)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<database_name>?retryWrites=true&w=majority

# JSON Web Token Secret (Create a strong, random string)
JWT_SECRET=your_super_secret_jwt_string_here

# Razorpay Payment Gateway Credentials (Get these from your Razorpay Dashboard)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_key_here
